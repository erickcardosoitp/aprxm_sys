# ============================================================
# APROXIMA (APRXM) — Environment Variables
# Copy to .env and fill in your values. NUNCA commitar .env.
# ============================================================

# --- PostgreSQL (Neon Serverless) ---
DATABASE_URL=postgresql+asyncpg://neondb_owner:SUA_SENHA@ep-xxxx-pooler.c-6.us-east-1.aws.neon.tech/neondb?ssl=true
DATABASE_URL_DIRECT=postgresql://neondb_owner:SUA_SENHA@ep-xxxx.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require

# --- Security ---
SECRET_KEY=gere_com_python_secrets_token_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Storage (Supabase) ---
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui
SUPABASE_STORAGE_BUCKET=aprxm-midia

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:5173,https://aprxm.vercel.app

# --- App ---
APP_ENV=development
APP_NAME=APROXIMA
APP_VERSION=1.0.0
DELIVERY_FEE_DEFAULT=2.50
