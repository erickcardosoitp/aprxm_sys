{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/api/v1/demands/reminders/trigger",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/v1/daily-tasks/reminders/trigger",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/v1/mensalidades/cron-generate",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/v1/mensalidades/cron-check-overdue",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/v1/datalake/run",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/v1/datalake/run",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/v1/ti/vacuum",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/v1/crm/cron-scoring",
      "schedule": "0 6 * * *"
    }
  ]
}
